{
  "$schema": "wheel-profile.schema.json",
  "schemaVersion": 2,
  "id": "PHUB_PBMR",
  "name": "Fanatec Podium Hub + Button Module Rally",
  "shortName": "Fanatec Podium Hub + BM Rally",
  "match": {
    "wheelType": "PHUB",
    "moduleType": "PBMR"
  },
  "display": "basic",
  "colorFormat": "rgb555",
  "leds": [
    { "channel": "buttonRgb", "hwIndex": 0,  "role": "button",  "label": "Top-left" },
    { "channel": "buttonRgb", "hwIndex": 1,  "role": "encoder", "label": "Right encoder" },
    { "channel": "buttonRgb", "hwIndex": 2,  "role": "button",  "label": "Mid-left upper" },
    { "channel": "buttonRgb", "hwIndex": 3,  "role": "button",  "label": "Mid-left lower" },
    { "channel": "buttonRgb", "hwIndex": 4,  "role": "button",  "label": "Bottom-left" },
    { "channel": "buttonRgb", "hwIndex": 5,  "role": "button",  "label": "Bottom-right" },
    { "channel": "buttonRgb", "hwIndex": 6,  "role": "button",  "label": "Mid-right lower" },
    { "channel": "buttonRgb", "hwIndex": 7,  "role": "button",  "label": "Mid-right upper" },
    { "channel": "buttonRgb", "hwIndex": 8,  "role": "encoder", "label": "Left encoder" },
    { "channel": "buttonRgb", "hwIndex": 9,  "role": "button",  "label": "Top-right" },
    { "channel": "buttonRgb", "hwIndex": 10, "role": "button",  "label": "Center" },
    { "channel": "buttonRgb", "hwIndex": 11, "role": "encoder", "label": "Center encoder" }
  ]
}
